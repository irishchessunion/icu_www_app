# Kamal secrets file. Sourced as a shell-like file by kamal at deploy time.
# Each line is `KEY=value`. Values can be literal or shell-expanded.
#
# Do NOT commit real secret values. The lines below read from local ENV
# vars (or shell-out to a password manager). Populate them on your machine
# via a .env file you don't commit, or via `op read` for 1Password.
#
# At minimum, set these in your shell or .env before running `kamal deploy`:
#   KAMAL_REGISTRY_PASSWORD  (GitHub PAT with `write:packages` scope)
#   SECRET_KEY_BASE          (Rails secret_key_base for staging)
#   DATABASE_PASSWORD        (MySQL password for the icu_www user)
#   MYSQL_ROOT_PASSWORD      (only needed on first `kamal accessory boot mysql`)
#   MYSQL_PASSWORD           (same value as DATABASE_PASSWORD)
#   STRIPE_PUBLIC_KEY / STRIPE_SECRET_KEY
#   MAILGUN_PASSWORD / MAILGUN_SECRET / MAILGUN_PUBLIC
#   GOOGLE_MAPS_API_KEY
#   PAPERCLIP_HASH_SECRET
#   SEASON_TICKET_BASE
#
# Example .env (gitignored):
#   KAMAL_REGISTRY_PASSWORD=ghp_xxx
#   SECRET_KEY_BASE=$(bin/rails secret)
#   DATABASE_PASSWORD=super-strong-password
#   ...

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
SECRET_KEY_BASE=$SECRET_KEY_BASE
DATABASE_PASSWORD=$DATABASE_PASSWORD
MYSQL_ROOT_PASSWORD=$MYSQL_ROOT_PASSWORD
MYSQL_PASSWORD=$MYSQL_PASSWORD
STRIPE_PUBLIC_KEY=$STRIPE_PUBLIC_KEY
STRIPE_SECRET_KEY=$STRIPE_SECRET_KEY
MAILGUN_PASSWORD=$MAILGUN_PASSWORD
MAILGUN_SECRET=$MAILGUN_SECRET
MAILGUN_PUBLIC=$MAILGUN_PUBLIC
GOOGLE_MAPS_API_KEY=$GOOGLE_MAPS_API_KEY
PAPERCLIP_HASH_SECRET=$PAPERCLIP_HASH_SECRET
SEASON_TICKET_BASE=$SEASON_TICKET_BASE
