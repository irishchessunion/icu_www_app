<%# bootstraps inbuilt scrollspy doesnt account for the offset correctly %>
$(function() {
  var data = ICU.Maps.readData("map-data");
  if (data && data.markers && data.markers.length) {
    ICU.Maps.init("map-canvas", data);
  }

  var $sections = $("#description, #contact, #links, #enter, #entries");
  var $navItems = $(".event-nav-sm li");

  if ($sections.length === 0 || $navItems.length === 0) return;

  var setActive = function(id) {
    $navItems.each(function() {
      var $item = $(this);
      var href = $item.find("a").attr("href");
      $item.toggleClass("active", href === "#" + id);
    });
  };

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        setActive(entry.target.id);
      }
    });
  }, {
    rootMargin: "-40px 0px -80% 0px",
    threshold: 0
  });

  $sections.each(function() {
    observer.observe(this);
  });
});